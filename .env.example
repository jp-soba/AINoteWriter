# X API credentials (Required)
X_API_KEY=
X_API_KEY_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# AI provider: claude_agent (Claude Code plan with optional CLI fallback)
AI_PROVIDER=claude_agent
AI_MODEL=claude-sonnet-4-5
AI_TIMEOUT_SEC=300
CLAUDE_CLI_PATH=claude
CLAUDE_MAX_TURNS=4
CLAUDE_USE_CLI_FALLBACK=true

# Discord Webhook URL for note draft notifications (optional)
DISCORD_WEBHOOK_URL=

# Optional app defaults
DEFAULT_NUM_POSTS=5
DEFAULT_TEST_MODE=true
DEFAULT_SUBMIT_NOTES=false
DEFAULT_EVALUATE_BEFORE_SUBMIT=true
DEFAULT_MIN_CLAIM_OPINION_SCORE=0.55

# Feed language is fixed in code: post_selection=feed_lang:ja